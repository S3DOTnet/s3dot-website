# ── S3DOT 環境変数サンプル ──────────────────────────────
# このファイルを .env.local にコピーして値を入力してください
# .env.local は .gitignore に含まれているため Git にはコミットされません

# 本番サイトURL（末尾スラッシュなし）
NEXT_PUBLIC_SITE_URL=https://www.s3dot.com

# Google Analytics 4 測定ID（G-XXXXXXXXXX 形式）
# 設定しない場合はGA読み込みをスキップします
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console 所有権確認コード
# Search Console > プロパティ追加 > HTMLタグの content 値をここに貼り付け
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=XXXXXXXXXXXXXXXXXX

# ── 無料相談フォーム（Resend） ──────────────────────────
# Resend API キー（https://resend.com/api-keys で取得）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 問い合わせ受信先メールアドレス（管理者通知の送信先）
CONTACT_TO_EMAIL=contact@s3dot.net

# 送信元メールアドレス（Resend で認証済みドメインのアドレスを使用）
# 例: noreply@s3dot.net または noreply@s3dot.com
# ※ Resend > Domains でドメインを追加・認証してから設定してください
CONTACT_FROM_EMAIL=noreply@s3dot.net
